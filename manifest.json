{
  "manifest_version": 3,
  "name": "GitHub Advanced PR Creator",
  "version": "1.3.2",
  "description": "Tạo nhanh Pull Request qua GitHub API",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "windows",
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://*.gevernova.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "git.png"
  },
  "icons": {
    "16": "git.png",
    "48": "git.png",
    "128": "git.png"
  }
}
